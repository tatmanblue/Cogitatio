# Source database (where you are migrating FROM)
SOURCE_DB_TYPE=MSSQL
SOURCE_CONNECTION_STRING=Server=localhost;Database=CogitatioBlog;User Id=sa;Password=yourpassword;TrustServerCertificate=True;
SOURCE_TENANT_ID=1

# Target database (where you are migrating TO)
TARGET_DB_TYPE=POSTGRES
TARGET_CONNECTION_STRING=Host=localhost;Database=cogitatio_blog;Username=postgres;Password=yourpassword;
TARGET_TENANT_ID=1

# Optional: explicit user database connection strings.
# If SOURCE_USER_CONNECTION_STRING is not set, the tool reads UserDBConnectionString
# from the source blog settings table, falling back to SOURCE_CONNECTION_STRING.
# If TARGET_USER_CONNECTION_STRING is not set, it defaults to TARGET_CONNECTION_STRING.
#
# SOURCE_USER_CONNECTION_STRING=
# TARGET_USER_CONNECTION_STRING=
